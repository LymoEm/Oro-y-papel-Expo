  m_GameObject: {fileID: 1499650512}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a6c0edf4aa3a28a46a64c844233690cf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::infoPaneles
  mainCamera: {fileID: 1252968921}
  cameraFocusPoint: {fileID: 1396311859}
  cameraSpeed: 4
  playerMovement: {fileID: 2029338671}
  panelUI: {fileID: 508465532}
  botonSaberMas: {fileID: 36106001}
  botonDatoCurioso: {fileID: 30044244}
  botonCerrar: {fileID: 434142552}
  imagenInicial: {fileID: 81675900}
  contenedorTexto: {fileID: 146921440}
  textoUI: {fileID: 146921442}
  textoCompleto: "Se crearon bibliotecas en zonas apartadas. Se reparti\xF3 la \"Biblioteca
    del Maestro\" de Losada (visi\xF3n laica). Pero tambi\xE9n editorial Bedout publicaba
    textos para \"obreros obedientes\". Ir\xF3nicamente, esos obreros aprendieron
    a leer y luego hicieron huelgas hist\xF3ricas."
  velocidadTexto: 0.03
  audioSource: {fileID: 28673435}
  audioDatoCurioso: {fileID: 8300000, guid: 0f1057cc883644b4db50777cabc10959, type: 3}
