  m_EditorClassIdentifier: Assembly-CSharp::infoPaneles
  mainCamera: {fileID: 1252968921}
  cameraFocusPoint: {fileID: 2008898152}
  cameraSpeed: 4
  playerMovement: {fileID: 2029338671}
  panelUI: {fileID: 1379119262}
  botonSaberMas: {fileID: 317441323}
  botonDatoCurioso: {fileID: 1971482353}
  botonCerrar: {fileID: 977720285}
  imagenInicial: {fileID: 6800093}
  contenedorTexto: {fileID: 1344246416}
  textoUI: {fileID: 1344246418}
  textoCompleto: "Los primeros anillos documentados se remontan al antiguo Egipto,
    hace unos 3000 a\xF1os, y eran de juncos o c\xE1\xF1amo, simbolizando la eternidad.
    Los romanos los hicieron de hierro como s\xEDmbolo de fuerza y permanencia, y
    crearon la idea de la 'vena amoris' que conectaba el dedo anular con el coraz\xF3n.
    Sin embargo, fue la Iglesia Cat\xF3lica, en el siglo XII, quien consolid\xF3
    el anillo como parte esencial del sacramento del matrimonio, una tradici\xF3n
    que lleg\xF3 a Colombia con los espa\xF1oles."
  velocidadTexto: 0.03
  audioSource: {fileID: 953926536}
  audioDatoCurioso: {fileID: 8300000, guid: 08a27294274059f49a9941da0ed53b48, type: 3}
