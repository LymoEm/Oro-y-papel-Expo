  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::infoPaneles
  mainCamera: {fileID: 1252968921}
  cameraFocusPoint: {fileID: 1388104240}
  cameraSpeed: 4
  playerMovement: {fileID: 2029338671}
  panelUI: {fileID: 1158989970}
  botonSaberMas: {fileID: 1001127199}
  botonDatoCurioso: {fileID: 116064899}
  botonCerrar: {fileID: 1343895033}
  imagenInicial: {fileID: 1143007340}
  contenedorTexto: {fileID: 1690527474}
  textoUI: {fileID: 1690527476}
  textoCompleto: "El sector de La Candelaria concentra talleres de orfebrer\xEDa
    desde el siglo XIX. All\xED, familias de clase media y alta encargaban anillos
    de oro con piedras. No era lujo extremo, pero s\xED un acceso privilegiado. Los
    anillos de esta exposici\xF3n fueron comprados en Joyas Calle Real, un negocio
    de ese sector."
  velocidadTexto: 0.03
  audioSource: {fileID: 249684239}
  audioDatoCurioso: {fileID: 8300000, guid: 824c9589ec7dfde409074fb3178a134b, type: 3}
