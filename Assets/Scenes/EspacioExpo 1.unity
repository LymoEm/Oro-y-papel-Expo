  m_Script: {fileID: 11500000, guid: a6c0edf4aa3a28a46a64c844233690cf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::infoPaneles
  mainCamera: {fileID: 1252968921}
  cameraFocusPoint: {fileID: 1697319636}
  cameraSpeed: 4
  playerMovement: {fileID: 2029338671}
  panelUI: {fileID: 275702953}
  botonSaberMas: {fileID: 1415526661}
  botonDatoCurioso: {fileID: 1815857879}
  botonCerrar: {fileID: 43778480}
  imagenInicial: {fileID: 1922898469}
  contenedorTexto: {fileID: 1544510832}
  textoUI: {fileID: 1544510834}
  textoCompleto: "El oro era un material sagrado para culturas prehisp\xE1nicas como
    los muiscas y quimbayas. Con la colonia, se convirti\xF3 en s\xEDmbolo de estatus
    para las \xE9lites. Las esmeraldas, hoy sin\xF3nimo de lujo, han estado rodeadas
    de una violenta historia conocida como la \"Guerra Verde\", especialmente entre
    1965 y 1990, donde el control de las minas dej\xF3 un saldo de miles de muertos."
  velocidadTexto: 0.03
  audioSource: {fileID: 1966367345}
  audioDatoCurioso: {fileID: 8300000, guid: 26c673814d9ccaf4580b827f40ad5064, type: 3}
